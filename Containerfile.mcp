# ── Football AI MCP Server ─────────────────────────────────────────────────────
FROM python:3.11-slim

WORKDIR /app

RUN pip install --no-cache-dir mcp[cli]==1.9.4 aiosqlite==0.20.0 python-dotenv==1.0.1

COPY backend/mcp_server/ ./backend/mcp_server/
COPY backend/__init__.py .
COPY .env .env

EXPOSE 8001

CMD ["python", "-m", "backend.mcp_server.server"]
